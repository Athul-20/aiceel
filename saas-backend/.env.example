APP_NAME=AICCEL Cloud API
APP_ENV=development
SECRET_KEY=replace-with-a-long-random-secret-min-32-chars
PREVIOUS_SECRET_KEYS=
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=43200
DATABASE_URL=sqlite:///./aiccel_saas.db
REDIS_URL=redis://localhost:6379/0
QUEUE_NAME=aiccel-jobs
QUEUE_JOB_TIMEOUT_SECONDS=120
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","file://","null"]
TRUSTED_HOSTS=["localhost","127.0.0.1"]
DEFAULT_PLAN_TIER=free
AUTH_BRUTEFORCE_LIMIT=8
AUTH_BRUTEFORCE_WINDOW_SECONDS=900
